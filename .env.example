# BeGood / NourishTrack local configuration

# Optional basic-auth password. If unset, local/dev access is open.
APP_PASSWORD="replace-with-local-password"

# Optional production sub-path. Production uses /begood; leave empty for root local dev.
NEXT_BASE_PATH="/begood"

# Optional SQLite/data locations. Defaults to ./data/begood.sqlite.
DATA_DIR="./data"
SQLITE_PATH="./data/begood.sqlite"

# LLM role config: disabled by default so builds/smokes make no paid calls.
# Providers: disabled | fake | openai-compatible
LLM_VISION_PROVIDER="disabled"
LLM_VISION_ENDPOINT="https://example-openai-compatible-host/v1/chat/completions"
LLM_VISION_MODEL="vision-model-placeholder"
LLM_VISION_API_KEY_ENV="LLM_VISION_API_KEY"
LLM_VISION_CONFIG_VERSION="vision-placeholder-v1"
# LLM_VISION_API_KEY="do-not-commit-real-keys"

LLM_ANALYSIS_PROVIDER="disabled"
LLM_ANALYSIS_ENDPOINT="https://example-openai-compatible-host/v1/chat/completions"
LLM_ANALYSIS_MODEL="analysis-model-placeholder"
LLM_ANALYSIS_API_KEY_ENV="LLM_ANALYSIS_API_KEY"
LLM_ANALYSIS_CONFIG_VERSION="analysis-placeholder-v1"
# LLM_ANALYSIS_API_KEY="do-not-commit-real-keys"

# Optional JSON config file. Copy config/llm.config.example.json to
# config/llm.config.json for local secret/provider config; that file is gitignored.
# LLM_CONFIG_PATH="./config/llm.config.json"
